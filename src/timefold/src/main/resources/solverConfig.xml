<?xml version="1.0" encoding="UTF-8"?>
<solver xmlns="https://timefold.ai/xsd/solver"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://timefold.ai/xsd/solver
                            https://timefold.ai/xsd/solver/solver.xsd">

    <environmentMode>NO_ASSERT</environmentMode>

    <!-- Domain model -->
    <solutionClass>com.pso.timefold.domain.ScheduleSolution</solutionClass>
    <entityClass>com.pso.timefold.domain.TaskAssignment</entityClass>

    <!-- Scoring -->
    <scoreDirectorFactory>
        <constraintProviderClass>com.pso.timefold.solver.ScheduleConstraintProvider</constraintProviderClass>
    </scoreDirectorFactory>

    <!-- Termination: used by the console runner.
         The Spring Boot API overrides this via application.properties
         (timefold.solver.termination.spent-limit). -->
    <termination>
        <spentLimit>PT15S</spentLimit>
    </termination>

    <!-- Construction heuristic: assign higher-difficulty tasks first -->
    <constructionHeuristic>
        <constructionHeuristicType>FIRST_FIT</constructionHeuristicType>
    </constructionHeuristic>

    <!-- Local search -->
    <localSearch>
        <termination>
            <unimprovedSpentLimit>PT5S</unimprovedSpentLimit>
        </termination>
        <acceptor>
            <entityTabuSize>10</entityTabuSize>
        </acceptor>
        <forager>
            <acceptedCountLimit>1000</acceptedCountLimit>
        </forager>
    </localSearch>

</solver>
