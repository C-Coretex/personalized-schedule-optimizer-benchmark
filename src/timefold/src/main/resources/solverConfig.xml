<?xml version="1.0" encoding="UTF-8"?>
<solver xmlns="https://timefold.ai/xsd/solver"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://timefold.ai/xsd/solver
                            https://timefold.ai/xsd/solver/solver.xsd">

    <environmentMode>REPRODUCIBLE</environmentMode>

    <!-- Domain model -->
    <solutionClass>com.pso.timefold.domain.ScheduleSolution</solutionClass>
    <entityClass>com.pso.timefold.domain.TaskAssignment</entityClass>

    <!-- Scoring -->
    <scoreDirectorFactory>
        <constraintProviderClass>com.pso.timefold.solver.ScheduleConstraintProvider</constraintProviderClass>
    </scoreDirectorFactory>

    <!-- Global termination: overridden programmatically by the console app (via SolverConfig)
         and by the Spring Boot service (via application.properties).
         This 15-second fallback is only used when neither override is provided. -->
    <termination>
        <spentLimit>PT15S</spentLimit>
    </termination>

    <!-- Construction heuristic: greedily assigns tasks in declaration order -->
    <constructionHeuristic>
        <constructionHeuristicType>FIRST_FIT</constructionHeuristicType>
    </constructionHeuristic>

    <!-- Local search: late acceptance, robust against local optima -->
    <localSearch>
        <acceptor>
            <simulatedAnnealingStartingTemperature>1hard/500soft</simulatedAnnealingStartingTemperature>
        </acceptor>
        <forager>
            <acceptedCountLimit>100</acceptedCountLimit>
        </forager>
    </localSearch>

</solver>
