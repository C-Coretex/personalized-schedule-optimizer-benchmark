<?xml version="1.0" encoding="UTF-8"?>
<solver xmlns="https://timefold.ai/xsd/solver"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://timefold.ai/xsd/solver
                            https://timefold.ai/xsd/solver/solver.xsd">

    <environmentMode>REPRODUCIBLE</environmentMode>

    <solutionClass>com.pso.timefold.domain.ScheduleSolution</solutionClass>
    <entityClass>com.pso.timefold.domain.TaskAssignment</entityClass>

    <scoreDirectorFactory>
        <constraintProviderClass>com.pso.timefold.solver.ScheduleConstraintProvider</constraintProviderClass>
    </scoreDirectorFactory>

    <termination>
        <spentLimit>PT15S</spentLimit>
    </termination>

    <constructionHeuristic>
        <constructionHeuristicType>FIRST_FIT</constructionHeuristicType>
    </constructionHeuristic>
    <localSearch>
        <!-- Phase 1: just fix hard constraints -->
        <termination>
            <spentLimit>PT3S</spentLimit>
        </termination>
        <acceptor>
            <simulatedAnnealingStartingTemperature>1hard/0soft</simulatedAnnealingStartingTemperature>
        </acceptor>
        <forager>
            <acceptedCountLimit>1</acceptedCountLimit>
        </forager>
    </localSearch>
    <localSearch>
        <termination>
            <bestScoreLimit>0hard/*soft</bestScoreLimit>
        </termination>
        <acceptor>
            <simulatedAnnealingStartingTemperature>0hard/1000soft</simulatedAnnealingStartingTemperature>
        </acceptor>
        <forager>
            <acceptedCountLimit>1</acceptedCountLimit>
        </forager>
    </localSearch>
    <!-- Phase 3: Fine-tuning with cooler SA — runs until overall termination -->
    <localSearch>
        <acceptor>
            <simulatedAnnealingStartingTemperature>0hard/300soft</simulatedAnnealingStartingTemperature>
        </acceptor>
        <forager>
            <acceptedCountLimit>10</acceptedCountLimit>
        </forager>
    </localSearch>
</solver>